{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {},
    "packages/*": {
      "entry": ["src/{index,main}.ts!"],
      "project": ["src/**/*.{ts,tsx}!", "build.config.ts"]
    }
  },
  "tags": ["-lintignore"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
